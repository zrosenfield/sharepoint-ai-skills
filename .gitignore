# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Secrets / credentials — never commit these
*.env
.env*
appsettings.local.json
secrets.json

# Node (if any tooling is added later)
node_modules/
npm-debug.log*

# Python (if any tooling is added later)
__pycache__/
*.py[cod]
.venv/

# Build / temp
dist/
*.tmp
*.log

# Demo tool — generated screenshots (debug output and run captures)
**/debug-screenshot.png
**/result-screenshot.png
tools/screenshots/
tools/step*.png

# Demo recordings — contain personal/client screen captures, never commit
tools/recordings/
recordings/

# Local demo tool config/vars — not committed so each machine can tune its own settings
tools/demo.config.json
tools/demo.vars.json

# Local-only demo scripts — not committed; use for unreleased / experimental features
tools/scripts/local/

# Playwright MCP — ephemeral session logs and snapshots
.playwright-mcp/

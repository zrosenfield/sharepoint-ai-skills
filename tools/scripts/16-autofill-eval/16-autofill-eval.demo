[new-chat]

[prompt: Delete the list called "Expected Outputs" if it exists.]

[wait]

[confirm: Click "Delete" in the SharePoint confirmation dialog]

[navigate: ${LIBRARY}]

[new-chat]

[prompt: Remove all autofill columns from this library — delete Document Type, Primary Company, Counterparty, Total Dollar Value, Time Period or Term, Key Risk or Limitation, Target Audience, Compliance Certifications, Executive Summary, and Action Required columns.]

[wait]

[new-chat]

[prompt: Delete all 5 documents from this Zava Test Documents library.]

[wait]

[new-chat]
